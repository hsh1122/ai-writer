# Copy this file to ".env" for local development, then fill in values.
# Do NOT commit real secrets (your real ".env" should be ignored by git).

# OpenAI / OpenAI-compatible API key.
# Leave empty to use the backend fallback template article.
OPENAI_API_KEY=

# Optional: Base URL for an OpenAI-compatible API (gateway/self-hosted).
# Examples:
# - https://api.openai.com/v1
# - http://127.0.0.1:8000/v1
OPENAI_BASE_URL=

# Model name used by the backend when calling the OpenAI-compatible API.
OPENAI_MODEL=gpt-4o-mini

